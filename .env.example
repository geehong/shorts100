# ── DB / Cache ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://shorts:shorts@fire_markets_db_postgres:5432/shorts100
REDIS_URL=redis://shorts100_redis:6379/0

# ── YouTube API (최대 3개 키 로테이션) ───────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_API_KEY1=
YOUTUBE_API_KEY2=

# ── 관리자 (T46: /admin/reports Basic Auth) ───────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=changeme   # 반드시 강한 비밀번호로 변경할 것

# ── Sentry 에러 트래킹 (T48) — 빈 값이면 비활성화 ──────────────────
SENTRY_DSN=

# ── 프론트엔드 ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://shorts100.firemarkets.net
NEXT_PUBLIC_SITE_URL=https://shorts100.com
NEXT_PUBLIC_SENTRY_DSN=

ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1255, the html cov report should be ignored
#   because it contains html files which are generated dynamically.
#   So, we ignore it here.
#   For more details: https://github.com/pypa/pipenv/issues/1255
#   We recommend to check Pipfile.lock into git, but if you like, you can ignore it.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in git.
#   However, if you want to ignore it, uncomment the line below.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in git.
#pdm.lock
#   pdm build stage
.pdm-plugins/

# Scrapy stuff:
.scrapy

